#alphabet<en>
/// Sorting algorithms
/// Demonstrates: loops, comparisons, list manipulation

z.o("=== Sorting Algorithms ===")

m 5 bubble_sort(5 lst) {
  5 cnt = z.len(lst)
  l (5 i = 0 : i < cnt - 1 : i = i + 1) {
    l (5 j = 0 : j < cnt - i - 1 : j = j + 1) {
      i (lst[j] > lst[j + 1]) {
        5 tmp = lst[j]
        lst[j] = lst[j + 1]
        lst[j + 1] = tmp
      }
    }
  }
  r lst
}

m 5 selection_sort(5 lst) {
  5 cnt = z.len(lst)
  l (5 i = 0 : i < cnt - 1 : i = i + 1) {
    5 min_idx = i
    l (5 j = i + 1 : j < cnt : j = j + 1) {
      i (lst[j] < lst[min_idx]) {
        min_idx = j
      }
    }
    i (min_idx != i) {
      5 tmp = lst[i]
      lst[i] = lst[min_idx]
      lst[min_idx] = tmp
    }
  }
  r lst
}

5 data1 = [64, 34, 25, 12, 22, 11, 90]
z.o("Original: " + z.tostr(data1))
z.o("Bubble:    " + z.tostr(bubble_sort(data1)))

5 data2 = [64, 34, 25, 12, 22, 11, 90]
z.o("Selection: " + z.tostr(selection_sort(data2)))
