#alphabet<en>
/// Alphabet Voice Tutorial
/// Teaches how to speak code for voice-to-text input
/// Run: alphabet voice-tutorial

z.o("╔══════════════════════════════════════════════════════╗")
z.o("║       ALPHABET VOICE INPUT TUTORIAL                  ║")
z.o("╚══════════════════════════════════════════════════════╝")
z.o("")
z.o("This tutorial teaches you how to speak code for")
z.o("the voice-to-text feature in Alphabet REPL.")
z.o("")
z.o("There are TWO modes:")
z.o("  1. CODE SPEECH — speak keywords directly")
z.o("  2. NATURAL SPEECH — speak naturally (English)")
z.o("")
z.o("Press Enter to continue...")
z.i()

z.o("")
z.o("═══════════════════════════════════════")
z.o("  MODE 1: CODE SPEECH")
z.o("═══════════════════════════════════════")
z.o("")
z.o("Speak Alphabet keywords directly:")
z.o("")
z.o("  WHAT YOU SAY                    WHAT YOU GET")
z.o("  ─────────────────────────────  ──────────────────────")
z.o("  \"i x greater than 5\"           i (x > 5)")
z.o("  \"e\"                            e")
z.o("  \"z.o hello world\"              z.o(\"hello world\")")
z.o("  \"5 x equals 10\"               5 x = 10")
z.o("  \"l 5 i equals 0 i less 10\"    l (5 i = 0 : i < 10")
z.o("  \"r x\"                          r x")
z.o("  \"m 5 add 5 a 5 b\"             m 5 add(5 a, 5 b)")
z.o("")
z.o("KEYWORDS TO REMEMBER:")
z.o("  i = if          e = else        l = loop")
z.o("  r = return      m = method      n = new")
z.o("  c = class       b = break       k = continue")
z.o("  z.o = print     z.i = input     x = import")
z.o("")
z.i()

z.o("")
z.o("═══════════════════════════════════════")
z.o("  MODE 2: NATURAL SPEECH (English)")
z.o("═══════════════════════════════════════")
z.o("")
z.o("Speak naturally — the system converts to code:")
z.o("")
z.o("  WHAT YOU SAY                         WHAT YOU GET")
z.o("  ────────────────────────────────────  ──────────────────────")
z.o("  \"if x greater than 5 then print hi\"  i (x > 5) { z.o(\"hi\") }")
z.o("  \"variable x equals 10\"              5 x = 10")
z.o("  \"set x to 20\"                       5 x = 20")
z.o("  \"function add takes a and b\"        m 5 add(5 a, 5 b)")
z.o("  \"loop from 1 to 10\"                l (5 i = 1 : i < 10")
z.o("  \"print hello world\"                 z.o(\"hello world\")")
z.o("  \"return x\"                          r x")
z.o("  \"x plus y\"                          (x + y)")
z.o("  \"x greater than y\"                  (x > y)")
z.o("")
z.i()

z.o("")
z.o("═══════════════════════════════════════")
z.o("  AMHARIC VOICE INPUT")
z.o("═══════════════════════════════════════")
z.o("")
z.o("Speak Amharic keywords directly:")
z.o("")
z.o("  WHAT YOU SAY                    WHAT YOU GET")
z.o("  ─────────────────────────────  ──────────────────────")
z.o("  \"ከሆነ x ከ 5 በላይ\"               i (x > 5)")
z.o("  \"ያለበለዚያ\"                      e")
z.o("  \"ውጤት ሰላም\"                     z.o(\"ሰላም\")")
z.o("  \"5 x እኩል 10\"                  5 x = 10")
z.o("  \"ተመለስ x\"                      r x")
z.o("")
z.o("AMHARIC KEYWORDS:")
z.o("  ከሆነ = if       ያለበለዚያ = else    ሉፕ = loop")
z.o("  ስበር = break    ቀጥል = continue    ተመለስ = return")
z.o("  ክፍል = class    ዘዴ = method       አዲስ = new")
z.o("  ውጤት = print    ግብአት = input      አስገባ = import")
z.o("")
z.i()

z.o("")
z.o("═══════════════════════════════════════")
z.o("  HOW TO USE")
z.o("═══════════════════════════════════════")
z.o("")
z.o("  1. Start REPL:     alphabet --repl")
z.o("  2. Type:           voice")
z.o("  3. Speak your code")
z.o("  4. Review what was heard")
z.o("  5. Edit if needed (voice fills buffer)")
z.o("  6. Press Enter to run")
z.o("")
z.o("  TIP: Voice fills the buffer but doesn't run")
z.o("       automatically. You can edit before running.")
z.o("")
z.i()

z.o("")
z.o("═══════════════════════════════════════")
z.o("  EXAMPLES")
z.o("═══════════════════════════════════════")
z.o("")
z.o("  EXAMPLE 1: Hello World")
z.o("  Speak: \"print hello world\"")
z.o("  Code:  z.o(\"hello world\")")
z.o("  Output: hello world")
z.o("")
z.o("  EXAMPLE 2: Variables")
z.o("  Speak: \"variable x equals 42\"")
z.o("  Code:  5 x = 42")
z.o("")
z.o("  EXAMPLE 3: If/Else")
z.o("  Speak: \"if x greater than 10 then print big\"")
z.o("  Code:  i (x > 10) { z.o(\"big\") }")
z.o("")
z.o("  EXAMPLE 4: Loop")
z.o("  Speak: \"loop from 1 to 5\"")
z.o("  Code:  l (5 i = 1 : i < 5 : i = i + 1)")
z.o("")
z.o("  EXAMPLE 5: Function")
z.o("  Speak: \"function add takes a and b\"")
z.o("  Code:  m 5 add(5 a, 5 b)")
z.o("")
z.i()

z.o("")
z.o("═══════════════════════════════════════")
z.o("  INSTALLATION")
z.o("═══════════════════════════════════════")
z.o("")
z.o("  For European languages (en/es/fr/de):")
z.o("    pip install vosk pyaudio")
z.o("")
z.o("  For Amharic:")
z.o("    pip install openai-whisper")
z.o("")
z.o("  Audio backends (if pyaudio fails):")
z.o("    sudo apt install portaudio19-dev  (Linux)")
z.o("    brew install portaudio            (macOS)")
z.o("")
z.i()

z.o("")
z.o("╔══════════════════════════════════════════════════════╗")
z.o("║  TUTORIAL COMPLETE!                                  ║")
z.o("╚══════════════════════════════════════════════════════╝")
z.o("")
z.o("  Try it now: alphabet --repl → type 'voice'")
z.o("")
