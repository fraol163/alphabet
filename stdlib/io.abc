#alphabet<en>
// Standard I/O Library for Alphabet
// Requires built-in: z.o (print), z.i (input), z.f (read file)

m 5 print(5 val) {
  z.o(val)
  r 0
}

m 5 println(5 val) {
  z.o(val)
  r 0
}

m 12 read_file(12 path) {
  r z.f(path)
}

m 5 write_file(12 path, 12 content) {
  // Note: write_file uses FFI or is not yet available
  // Placeholder for future implementation
  z.o("write_file not yet implemented")
  r 0
}
