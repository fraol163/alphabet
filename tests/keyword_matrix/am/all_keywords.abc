ዘዴ 5 gmv(5 num) { ምረጥ (num) { 1: ተመለስ 10 2: ተመለስ 20 e: ተመለስ 0 } }
ከሆነ (gmv(1)==10 && gmv(2)==20) { o("P:q4") }
ዘዴ 5 mrt(5 num) { ምረጥ (num) { 1: ተመለስ 1 2: ተመለስ 2 e: ተመለስ 0 } }
ከሆነ (mrt(1)==1) { o("P:q5") }
5 mm2=2 5 mr2=0
ምረጥ (mm2) { 1: mr2=1 2: mr2=22 e: mr2=0 }
ከሆነ (mr2==22) { o("P:q6") }
5 ms2=0 5 mv3=0
ምረጥ (mv3) { 0: ሉፕ (ms2<5) { ms2=ms2+1 } e: ms2=-1 }
ከሆነ (ms2==5) { o("P:q7") }

ክፍል Animal { ግልጽ 12 an="" ግልጽ ዘዴ 12 sp() { ተመለስ "..." } }
ክፍል Dog ^ Animal { ግልጽ ዘዴ 12 sp() { ተመለስ "woof" } }
15 dog=num Dog() dog.an="Rex"
ከሆነ (dog.sp()=="woof" && dog.an=="Rex") { o("P:x1") }
15 an2=num Animal() an2.an="Gen"
ከሆነ (an2.an=="Gen") { o("P:x2") }
ክፍል Cat ^ Animal { ግልጽ ዘዴ 12 sp() { ተመለስ "meow" } }
15 cat=num Cat()
ከሆነ (cat.sp()=="meow") { o("P:x3") }
ክፍል Rob ^ Animal { ግልጽ ዘዴ 5 bp() { ተመለስ 42 } }
15 rb=num Rob()
ከሆነ (rb.bp()==42 && rb.sp()=="...") { o("P:x4") }
ክፍል Pet ^ Animal { ግልጽ 5 loy=100 }
15 pet=num Pet()
ከሆነ (pet.loy==100) { o("P:x5") }
ክፍል Bas { ግልጽ ዘዴ 5 bf() { ተመለስ 1 } }
ክፍል Mid2 ^ Bas { ግልጽ ዘዴ 5 mf3() { ተመለስ 2 } }
ክፍል Top2 ^ Mid2 { ግልጽ ዘዴ 5 tf() { ተመለስ 3 } }
15 t2=num Top2()
ከሆነ (t2.bf()==1 && t2.mf3()==2 && t2.tf()==3) { o("P:x6") }

ላክ efn
ዘዴ 5 efn() { ተመለስ 42 }
ከሆነ (efn()==42) { o("P:@1") }
ላክ EV
5 EV=99
ከሆነ (EV==99) { o("P:@2") }
o("P:@3")

