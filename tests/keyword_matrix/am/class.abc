#alphabet<am>
// === CLASS TESTS ===
// S1: empty class
ክፍል Empty { }
z.o("PASS:class_s1")
// S2: one method
ክፍል Greeter { ግልጽ ዘዴ 12 hello() { r "hello" } }
15 g = n Greeter()
ከሆነ (g.hello() == "hello") { z.o("PASS:class_s2") }
// S3: multiple methods
ክፍል Calc { ግልጽ ዘዴ 11 add(11 num_a, 11 num_b) { r num_a + num_b } ግልጽ ዘዴ 11 mul(11 num_a, 11 num_b) { r num_a * num_b } }
15 cc = n Calc()
ከሆነ (cc.add(2, 3) == 5 && cc.mul(2, 3) == 6) { z.o("PASS:class_s3") }
// S4: public fields
ክፍል Point { ግልጽ 5 px = 0 ግልጽ 5 py = 0 }
15 pt = n Point()
pt.px = 10
pt.py = 20
ከሆነ (pt.px == 10 && pt.py == 20) { z.o("PASS:class_s4") }
// S5: static method
ክፍል MathUtil { ግልጽ ቋሚ 11 add(11 num_a, 11 num_b) { r num_a + num_b } }
ከሆነ (MathUtil.add(3, 4) == 7) { z.o("PASS:class_s5") }
// S6: method calling method
ክፍል Counter { ግልጽ 5 cnt = 0 ግልጽ ዘዴ 11 increment() { cnt = cnt + 1 } ግልጽ ዘዴ 11 get_count() { r cnt } }
15 cn = n Counter()
cn.increment()
cn.increment()
cn.increment()
ከሆነ (cn.get_count() == 3) { z.o("PASS:class_s6") }
// S7: field initialization
ክፍል Config { ግልጽ 12 cfg_name = "default" ግልጽ 5 cfg_val = 42 }
15 cfg = n Config()
ከሆነ (cfg.cfg_name == "default" && cfg.cfg_val == 42) { z.o("PASS:class_s7") }
// S8: list field
ክፍል Basket { ግልጽ 13 items = [] ግልጽ ዘዴ 11 add_item(11 item_a) { z.append(items, item_a) } ግልጽ ዘዴ 11 count() { r z.len(items) } }
15 bt = n Basket()
bt.add_item(10)
bt.add_item(20)
ከሆነ (bt.count() == 2) { z.o("PASS:class_s8") }
// S9: map field
ክፍል Store { ግልጽ 14 store_data = {"key": "val"} }
15 st = n Store()
ከሆነ (st.store_data["key"] == "val") { z.o("PASS:class_s9") }
// S10: multiple instances
15 a1 = n Greeter()
15 a2 = n Greeter()
ከሆነ (a1.hello() == a2.hello()) { z.o("PASS:class_s10") }
