#alphabet<am>
// === ELSE TESTS ===
5 val_a = 10
// S1: true path
ከሆነ (val_a == 10) { z.o("PASS:else_s1") } ያለበለዚያ { z.o("FAIL:else_s1") }
// S2: false path
ከሆነ (val_a == 20) { z.o("FAIL:else_s2") } ያለበለዚያ { z.o("PASS:else_s2") }
// S3: 3-branch
5 val_b = 15
ከሆነ (val_b < 10) { z.i("low") } ያለበለዚያ ከሆነ (val_b < 20) { z.o("PASS:else_s3") } ያለበለዚያ { z.i("high") }
// S4: 4+ branch
5 val_c = 25
ከሆነ (val_c < 10) { z.i("a") } ያለበለዚያ ከሆነ (val_c < 20) { z.i("b") } ያለበለዚያ ከሆነ (val_c < 30) { z.o("PASS:else_s4") } ያለበለዚያ { z.i("d") }
// S5: nested if in if
ከሆነ (val_a == 10) { ከሆነ (val_a > 5) { z.o("PASS:else_s5") } }
// S6: nested if in else
ከሆነ (val_a == 20) { z.i("no") } ያለበለዚያ { ከሆነ (val_a == 10) { z.o("PASS:else_s6") } }
// S7: return in both
ዘዴ 11 test_ret(11 num_a) { ከሆነ (num_a > 0) { r 1 } ያለበለዚያ { r 0 } }
ከሆነ (test_ret(5) == 1 && test_ret(-1) == 0) { z.o("PASS:else_s7") }
// S8: assignment in both
5 result_a = 0
ከሆነ (val_a == 10) { result_a = 1 } ያለበለዚያ { result_a = 2 }
ከሆነ (result_a == 1) { z.o("PASS:else_s8") }
// S9: in loop
5 cnt_a = 0
ሉፕ (cnt_a < 3) { ከሆነ (cnt_a == 1) { z.o("PASS:else_s9") } ያለበለዚያ { z.i("skip") } cnt_a = cnt_a + 1 }
// S10: in class method
ክፍል ElseCls { ግልጽ ዘዴ 11 check(11 num_a) { ከሆነ (num_a > 0) { r 1 } ያለበለዚያ { r -1 } } }
15 obj_a = n ElseCls()
ከሆነ (obj_a.check(5) == 1 && obj_a.check(-5) == -1) { z.o("PASS:else_s10") }
// S11: complex condition
5 val_x = 5
5 val_y = 10
ከሆነ (val_x > 3 && val_y < 15) { z.o("PASS:else_s11") } ያለበለዚያ { z.i("FAIL") }
// S12: f-string in both
ከሆነ (val_a == 10) { z.i(f"PASS:else_s12a val={val_a}") } ያለበለዚያ { z.i("FAIL") }
// S13: list ops
13 lst_a = [1, 2]
13 lst_b = [3, 4]
z.append(lst_a, 5)
z.append(lst_b, 6)
ከሆነ (z.len(lst_a) == 3) { z.o("PASS:else_s13") }
