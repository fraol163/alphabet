#alphabet<am>
// === RETURN TESTS ===
// S1: int value
ዘዴ 11 ret_int() { r 42 }
ከሆነ (ret_int() == 42) { z.o("PASS:ret_s1") }
// S2: string value
ዘዴ 12 ret_str() { r "hello" }
ከሆነ (ret_str() == "hello") { z.o("PASS:ret_s2") }
// S3: float value
ዘዴ 8 ret_float() { r 3.14 }
ከሆነ (z.type(ret_float()) == "number") { z.o("PASS:ret_s3") }
// S4: bool value
ዘዴ 11 ret_bool() { r true }
ከሆነ (ret_bool()) { z.o("PASS:ret_s4") }
// S5: list
13 ret_list() { r [1, 2, 3] }
13 rl = ret_list()
ከሆነ (z.len(rl) == 3) { z.o("PASS:ret_s5") }
// S6: map
14 ret_map() { r {"a": 1} }
14 rm = ret_map()
ከሆነ (z.has(rm, "a")) { z.o("PASS:ret_s6") }
// S7: no value
ዘዴ 11 ret_null() { }
ret_null()
z.o("PASS:ret_s7")
// S8: from if/else
ዘዴ 11 abs_val(11 num_a) { ከሆነ (num_a >= 0) { r num_a } ያለበለዚያ { r 0 - num_a } }
ከሆነ (abs_val(5) == 5 && abs_val(-5) == 5) { z.o("PASS:ret_s8") }
// S9: from loop
ዘዴ 11 find_in_loop(11 target) { 5 idx_a = 0 ሉፕ (idx_a < 10) { ከሆነ (idx_a == target) { r idx_a } idx_a = idx_a + 1 } r -1 }
ከሆነ (find_in_loop(7) == 7) { z.o("PASS:ret_s9") }
// S10: recursive factorial
ዘዴ 11 fact(11 num_a) { ከሆነ (num_a <= 1) { r 1 } r num_a * fact(num_a - 1) }
ከሆነ (fact(5) == 120) { z.o("PASS:ret_s10") }
// S11: multiple returns
ዘዴ 11 multi_ret(11 num_a) { ከሆነ (num_a > 0) { r 1 } ከሆነ (num_a == 0) { r 0 } r -1 }
ከሆነ (multi_ret(5) == 1 && multi_ret(0) == 0 && multi_ret(-5) == -1) { z.o("PASS:ret_s11") }
// S12: return expression
ዘዴ 11 calc(11 num_a, 11 num_b) { r num_a * num_b + num_a - num_b }
ከሆነ (calc(3, 2) == 7) { z.o("PASS:ret_s12") }
// S13: return function call
ዘዴ 11 double_it(11 num_a) { r num_a * 2 }
ዘዴ 11 triple_it(11 num_a) { r double_it(num_a) + num_a }
ከሆነ (triple_it(5) == 15) { z.o("PASS:ret_s13") }
// S14: in class method
ክፍል RetCls { ግልጽ ዘዴ 11 get_val() { r 99 } }
15 rc = n RetCls()
ከሆነ (rc.get_val() == 99) { z.o("PASS:ret_s14") }
