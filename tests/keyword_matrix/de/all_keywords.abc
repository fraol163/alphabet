// EXTENDS
klasse Animal { öffentlich 12 an="" öffentlich m 12 sp() { r "..." } }
klasse Dog ^ Animal { öffentlich m 12 sp() { r "woof" } }
15 dog=n Dog() dog.an="Rex"
wenn (dog.sp()=="woof" && dog.an=="Rex") { o("P:x1") }
15 an2=n Animal() an2.an="Gen"
wenn (an2.an=="Gen") { o("P:x2") }
klasse Cat ^ Animal { öffentlich m 12 sp() { r "meow" } }
15 cat=n Cat()
wenn (cat.sp()=="meow") { o("P:x3") }
klasse Rob ^ Animal { öffentlich m 5 bp() { r 42 } }
15 rb=n Rob()
wenn (rb.bp()==42 && rb.sp()=="...") { o("P:x4") }
klasse Pet ^ Animal { öffentlich 5 loy=100 }
15 pet=n Pet()
wenn (pet.loy==100) { o("P:x5") }
klasse Bas2 { öffentlich m 5 bf() { r 1 } }
klasse Mid3 ^ Bas2 { öffentlich m 5 mf4() { r 2 } }
klasse Top3 ^ Mid3 { öffentlich m 5 tf() { r 3 } }
15 t2=n Top3()
wenn (t2.bf()==1 && t2.mf4()==2 && t2.tf()==3) { o("P:x6") }
