// LOOP
5 s1=0 5 ix=0
schleife (ix<5) { s1=s1+ix ix=ix+1 }
wenn (s1==10) { o("P:l1") }
5 g1=10
schleife (g1<5) { o("F") }
o("P:l2")
5 bv=0
schleife (true) { bv=bv+1 wenn (bv==5) { b } }
wenn (bv==5) { o("P:l3") }
13 ev=[] 5 ci=0
schleife (ci<10) { ci=ci+1 wenn (ci%2!=0) { k } z.append(ev,ci) }
wenn (z.len(ev)==5) { o("P:l4") }
13 rx=[] 5 ri=0
schleife (ri<10) { ri=ri+1 wenn (ri==3) { k } wenn (ri==8) { b } z.append(rx,ri) }
wenn (z.len(rx)==6) { o("P:l5") }
5 ps=0 5 pi=0
schleife (pi<3) { 5 pj=0 schleife (pj<3) { ps=ps+1 pj=pj+1 } pi=pi+1 }
wenn (ps==9) { o("P:l6") }
5 c3=0 5 p1=0
schleife (p1<2) { 5 p2=0 schleife (p2<2) { 5 p3=0 schleife (p3<2) { c3=c3+1 p3=p3+1 } p2=p2+1 } p1=p1+1 }
wenn (c3==8) { o("P:l7") }
m 5 ff() { 5 fi=0 schleife (fi<10) { wenn (fi==5) { r fi } fi=fi+1 } r -1 }
wenn (ff()==5) { o("P:l8") }
5 od=0 5 oi=0
schleife (oi<10) { wenn (oi%2==1) { od=od+1 } oi=oi+1 }
wenn (od==5) { o("P:l9") }
5 ext=0
schleife (ext<5) { ext=ext+1 }
wenn (ext==5) { o("P:l10") }
12 rs="" 5 si2=0
schleife (si2<3) { rs=rs+z.tostr(si2) si2=si2+1 }
wenn (rs=="012") { o("P:l11") }
13 bd=[] 5 bi=0
schleife (bi<5) { z.append(bd,bi*2) bi=bi+1 }
wenn (z.len(bd)==5) { o("P:l12") }
5 cn=0
m 5 sgo() { r cn<3 }
schleife (sgo()) { cn=cn+1 }
wenn (cn==3) { o("P:l13") }
5 inf=0
schleife (true) { inf=inf+1 wenn (inf>=100) { b } }
wenn (inf==100) { o("P:l14") }
5 tp=0
schleife (tp<1) { o(f"P:l15 tp={tp}") tp=tp+1 }
// BREAK
5 bv2=0
schleife (true) { bv2=bv2+1 wenn (bv2==5) { b } }
wenn (bv2==5) { o("P:b1") }
5 bv3=0
schleife (true) { bv3=bv3+1 wenn (bv3==3) { wenn (true) { b } } }
wenn (bv3==3) { o("P:b2") }
5 inn=0 5 ot=0
schleife (ot<5) { inn=0 schleife (true) { inn=inn+1 wenn (inn==2) { b } } ot=ot+1 }
wenn (inn==2 && ot==5) { o("P:b3") }
5 bv4=0
schleife (bv4<10) { bv4=bv4+1 b }
wenn (bv4==1) { o("P:b4") }
13 nm2=[1,2,3,4,5] 5 ix2=0 5 fv=0
schleife (ix2<z.len(nm2)) { wenn (nm2[ix2]==3) { fv=nm2[ix2] b } ix2=ix2+1 }
wenn (fv==3) { o("P:b5") }
5 bc=0 5 ba=0
schleife (bc<10) { ba=ba+bc bc=bc+1 wenn (bc==4) { b } }
wenn (bc==4 && ba==6) { o("P:b6") }
5 bk=0 5 bs=0
schleife (bk<5) { bs=bs+bk bk=bk+1 wenn (bk==3) { b } }
wenn (bs==3) { o("P:b7") }
// CONTINUE
13 kp=[] 5 ci2=0
schleife (ci2<5) { ci2=ci2+1 wenn (ci2==3) { k } z.append(kp,ci2) }
wenn (z.len(kp)==4) { o("P:k1") }
13 kr=[] 5 cj=0
schleife (cj<5) { cj=cj+1 wenn (cj==3) { wenn (true) { k } } z.append(kr,cj) }
wenn (z.len(kr)==4) { o("P:k2") }
5 ic=0 5 ck2=0
schleife (ck2<3) { ic=0 5 cl=0 schleife (cl<3) { cl=cl+1 wenn (cl==2) { k } ic=ic+1 } ck2=ck2+1 }
wenn (ic==2) { o("P:k3") }
13 ce=[] 5 cv=0
schleife (cv<6) { cv=cv+1 wenn (cv%2!=0) { k } z.append(ce,cv) }
wenn (z.len(ce)==3) { o("P:k4") }
13 cq=[] 5 cw=0
schleife (cw<8) { cw=cw+1 wenn (cw%3==0) { k } z.append(cq,cw) }
wenn (z.len(cq)==5) { o("P:k5") }
13 cm=[] 5 cx=0
schleife (cx<10) { cx=cx+1 wenn (cx==3) { k } wenn (cx==8) { b } z.append(cm,cx) }
wenn (z.len(cm)==6) { o("P:k6") }
m 5 cnz() { 13 dt=[0,1,0,2,0,3] 5 ct=0 5 di=0 schleife (di<z.len(dt)) { wenn (dt[di]==0) { di=di+1 k } ct=ct+1 di=di+1 } r ct }
wenn (cnz()==3) { o("P:k7") }
// RETURN
m 5 ri1() { r 42 }
wenn (ri1()==42) { o("P:r1") }
m 12 rs1() { r "hello" }
wenn (rs1()=="hello") { o("P:r2") }
m 8 rf1() { r 3.14 }
wenn (z.type(rf1())=="number") { o("P:r3") }
m 5 rl1() { r [1,2,3] }
13 rlv=rl1()
wenn (z.len(rlv)==3) { o("P:r4") }
m 5 abs1(5 num) { wenn (num>=0) { r num } sonst { r 0-num } }
wenn (abs1(5)==5 && abs1(-5)==5) { o("P:r5") }
m 5 flp(5 tgt) { 5 fi=0 schleife (fi<10) { wenn (fi==tgt) { r fi } fi=fi+1 } r -1 }
wenn (flp(7)==7) { o("P:r6") }
m 5 fact(5 num) { wenn (num<=1) { r 1 } r num*fact(num-1) }
wenn (fact(5)==120) { o("P:r7") }
m 5 mret(5 num) { wenn (num>0) { r 1 } wenn (num==0) { r 0 } r -1 }
wenn (mret(5)==1 && mret(0)==0 && mret(-5)==-1) { o("P:r8") }
m 5 clc(5 a, 5 b) { r a*b+a-b }
wenn (clc(3,2)==7) { o("P:r9") }
m 5 dbl2(5 num) { r num*2 }
m 5 trp(5 num) { r dbl2(num)+num }
