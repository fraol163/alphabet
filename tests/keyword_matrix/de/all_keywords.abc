#alphabet<de>
// COMPLETE KEYWORD TEST: DE (using working keywords)
5 wert = 10
// IF
wenn (wert == 10) { o("P:if1") }
wenn (wert == 20) { o("F") } sonst { o("P:if2") }
wenn (wert > 5) { o("P:if3") }
wenn (wert < 5) { o("F") } sonst { o("P:if4") }
