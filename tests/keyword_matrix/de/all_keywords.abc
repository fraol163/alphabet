15 ccc = n Calc()
wenn (ccc.add(2,3)==5 && ccc.mul(2,3)==6) { o("P:c3") }
klasse Pt { öffentlich 5 px=0 öffentlich 5 py=0 }
15 ptt = n Pt()
ptt.px=10 ptt.py=20
wenn (ptt.px==10 && ptt.py==20) { o("P:c4") }
klasse Cntr { öffentlich 5 cv=0 öffentlich m 5 inc() { cv=cv+1 } öffentlich m 5 get() { r cv } }
15 ccc2 = n Cntr()
ccc2.inc() ccc2.inc() ccc2.inc()
