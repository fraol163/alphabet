m 5 stn(5 num) { 5 ss2=0 5 si3=0 schleife (si3<num) { ss2=ss2+si3 si3=si3+1 } r ss2 }
wenn (stn(5)==10) { o("P:m9") }
m 5 nr() { 5 xv=10 }
nr()
o("P:m10")
// CLASS
klasse Empty { }
o("P:c1")
klasse Greeter { öffentlich m 12 hello() { r "hello" } }
15 gg = n Greeter()
wenn (gg.hello()=="hello") { o("P:c2") }
