wenn (wert == 5 || wert == 10) { o("P:if6") }
wenn (!(wert == 20)) { o("P:if7") }
wenn (wert > 5) { wenn (wert > 8) { o("P:if8") } }
12 nm = "hello"
wenn (nm == "hello") { o("P:if9") }
13 lt = [1,2,3]
wenn (z.len(lt) == 3) { o("P:if10") }
14 mp = {"k":100}
wenn (z.has(mp,"k")) { o("P:if11") }
m 5 ispos(5 num) { r num > 0 }
wenn (ispos(5)) { o("P:if12") }
wenn (wert == 10) { o(f"P:if13 v={wert}") }
wenn (wert == 10) o("P:if14")
m 5 testif() { wenn (1==1) { r 1 } r 0 }
wenn (testif()==1) { o("P:if15") }
// ELSE
wenn (wert==10) { o("P:e1") } sonst { o("F") }
wenn (wert==20) { o("F") } sonst { o("P:e2") }
5 d1 = 15
wenn (d1<10) { o("lo") } sonst wenn (d1<20) { o("P:e3") } sonst { o("hi") }
wenn (wert==10) { wenn (wert>5) { o("P:e4") } }
wenn (wert==20) { o("no") } sonst { wenn (wert==10) { o("P:e5") } }
m 5 tret(5 num) { wenn (num>0) { r 1 } sonst { r 0 } }
wenn (tret(5)==1 && tret(-1)==0) { o("P:e6") }
5 res = 0
wenn (wert==10) { res=1 } sonst { res=2 }
wenn (res==1) { o("P:e7") }
13 la = [1,2]
z.append(la,5)
wenn (z.len(la)==3) { o("P:e8") }
klasse ECls { öffentlich m 5 ck(5 num) { wenn (num>0) { r 1 } sonst { r -1 } } }
15 oc = n ECls()
wenn (oc.ck(5)==1 && oc.ck(-1)==-1) { o("P:e9") }
