wenn (add3(1,2,3)==6) { o("P:m3") }
m 12 grt(12 nm) { r "hello "+nm }
wenn (grt("world")=="hello world") { o("P:m4") }
m 5 sq2(5 num) { r num*num }
m 5 ssq(5 a, 5 b) { r sq2(a)+sq2(b) }
wenn (ssq(3,4)==25) { o("P:m5") }
m 5 fib2(5 num) { wenn (num<=1) { r num } r fib2(num-1)+fib2(num-2) }
wenn (fib2(10)==55) { o("P:m6") }
