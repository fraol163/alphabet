#alphabet<de>
// === CONST TESTS ===
// S1: const int
konstante 5 MAX = 100
wenn (MAX == 100) { z.o("PASS:const_s1") }
// S2: const string
konstante 12 CNAME = "Alphabet"
wenn (CNAME == "Alphabet") { z.o("PASS:const_s2") }
// S3: const bool
konstante 11 DEBUG = true
wenn (DEBUG) { z.o("PASS:const_s3") }
// S4: const float
konstante 8 CPI = 3.14
wenn (z.type(CPI) == "number") { z.o("PASS:const_s4") }
// S5: const in expression
konstante 5 CLIMIT = 10
5 half = CLIMIT / 2
wenn (half == 5) { z.o("PASS:const_s5") }
// S6: const passed to function
methode 11 check_limit(11 num_a) { r num_a < 100 }
wenn (check_limit(MAX)) { z.o("PASS:const_s6") }
// S7: const in function scope
methode 11 use_const() { konstante 5 LOCAL = 50 r LOCAL }
wenn (use_const() == 50) { z.o("PASS:const_s7") }
