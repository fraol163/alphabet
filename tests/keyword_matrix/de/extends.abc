#alphabet<de>
// === EXTENDS TESTS ===
klasse Animal { öffentlich 12 aname = "" öffentlich methode 12 speak() { r "..." } }
// S1: inherit method + field
klasse Dog erweitert Animal { öffentlich methode 12 speak() { r "woof" } }
15 d = n Dog()
d.aname = "Rex"
wenn (d.speak() == "woof" && d.aname == "Rex") { z.o("PASS:ext_s1") }
// S2: inherit field
15 a = n Animal()
a.aname = "Generic"
wenn (a.aname == "Generic") { z.o("PASS:ext_s2") }
// S3: override method
klasse Cat erweitert Animal { öffentlich methode 12 speak() { r "meow" } }
15 ct = n Cat()
wenn (ct.speak() == "meow") { z.o("PASS:ext_s3") }
// S4: child adds method
klasse Robot erweitert Animal { öffentlich methode 11 beep() { r 42 } }
15 rb = n Robot()
wenn (rb.beep() == 42 && rb.speak() == "...") { z.o("PASS:ext_s4") }
// S5: child adds field
klasse Pet erweitert Animal { öffentlich 5 loyalty = 100 }
15 pt = n Pet()
wenn (pt.loyalty == 100) { z.o("PASS:ext_s5") }
// S6: 3-level chain
klasse Base { öffentlich methode 11 base_fn() { r 1 } }
klasse Mid erweitert Base { öffentlich methode 11 mid_fn() { r 2 } }
klasse Top erweitert Mid { öffentlich methode 11 top_fn() { r 3 } }
15 tp = n Top()
wenn (tp.base_fn() == 1 && tp.mid_fn() == 2 && tp.top_fn() == 3) { z.o("PASS:ext_s6") }
