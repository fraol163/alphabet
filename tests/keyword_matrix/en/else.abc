l (cnt_a < 3) { i (cnt_a == 1) { z.o("PASS:else_s9") } e { z.i("skip") } cnt_a = cnt_a + 1 }
// S10: in class method
c ElseCls { v m 11 check(11 num_a) { i (num_a > 0) { r 1 } e { r -1 } } }
15 obj_a = n ElseCls()
i (obj_a.check(5) == 1 && obj_a.check(-5) == -1) { z.o("PASS:else_s10") }
// S11: complex condition
5 val_x = 5
