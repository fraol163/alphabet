// S4: 4+ branch
5 val_c = 25
i (val_c < 10) { z.i("a") } e i (val_c < 20) { z.i("b") } e i (val_c < 30) { z.o("PASS:else_s4") } e { z.i("d") }
// S5: nested if in if
i (val_a == 10) { i (val_a > 5) { z.o("PASS:else_s5") } }
