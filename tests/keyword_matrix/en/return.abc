#alphabet<en>
// === RETURN TESTS ===
// S1: int value
m 5 ret_int() { r 42 }
i (ret_int() == 42) { z.o("PASS:ret_s1") }
// S2: string value
m 12 ret_str() { r "hello" }
i (ret_str() == "hello") { z.o("PASS:ret_s2") }
// S3: float value
m 8 ret_float() { r 3.14 }
i (z.type(ret_float()) == "number") { z.o("PASS:ret_s3") }
// S4: bool value
m 5 ret_bool() { r true }
i (ret_bool()) { z.o("PASS:ret_s4") }
// S5: list
13 ret_list() { r [1, 2, 3] }
13 rl = ret_list()
i (z.len(rl) == 3) { z.o("PASS:ret_s5") }
// S6: map
14 ret_map() { r {"a": 1} }
14 rm = ret_map()
i (z.has(rm, "a")) { z.o("PASS:ret_s6") }
// S7: no value
m 5 ret_null() { }
ret_null()
z.o("PASS:ret_s7")
// S8: from if/else
m 5 abs_val(11 num_a) { i (num_a >= 0) { r num_a } e { r 0 - num_a } }
i (abs_val(5) == 5 && abs_val(-5) == 5) { z.o("PASS:ret_s8") }
// S9: from loop
m 5 find_in_loop(11 target) { 5 idx_a = 0 l (idx_a < 10) { i (idx_a == target) { r idx_a } idx_a = idx_a + 1 } r -1 }
i (find_in_loop(7) == 7) { z.o("PASS:ret_s9") }
// S10: recursive factorial
m 5 fact(11 num_a) { i (num_a <= 1) { r 1 } r num_a * fact(num_a - 1) }
i (fact(5) == 120) { z.o("PASS:ret_s10") }
// S11: multiple returns
m 5 multi_ret(11 num_a) { i (num_a > 0) { r 1 } i (num_a == 0) { r 0 } r -1 }
i (multi_ret(5) == 1 && multi_ret(0) == 0 && multi_ret(-5) == -1) { z.o("PASS:ret_s11") }
// S12: return expression
m 5 calc(11 num_a, 11 num_b) { r num_a * num_b + num_a - num_b }
i (calc(3, 2) == 7) { z.o("PASS:ret_s12") }
// S13: return function call
m 5 double_it(11 num_a) { r num_a * 2 }
m 5 triple_it(11 num_a) { r double_it(num_a) + num_a }
i (triple_it(5) == 15) { z.o("PASS:ret_s13") }
// S14: in class method
c RetCls { v m 5 get_val() { r 99 } }
15 rc = n RetCls()
i (rc.get_val() == 99) { z.o("PASS:ret_s14") }
