#alphabet<es>
// === ACCESS (public/private/static) TESTS ===
// S1: public method callable
público método 11 pub_fn() { r 1 }
si (pub_fn() == 1) { z.o("PASS:access_s1") }
// S2: public field accessible
público 5 pub_var = 42
si (pub_var == 42) { z.o("PASS:access_s2") }
// S3: class with public method
clase AccessCls { público método 11 greet() { r "hi" } }
15 ac = n AccessCls()
si (ac.greet() == "hi") { z.o("PASS:access_s3") }
// S4: class with public field
clase FieldCls { público 5 fld_x = 10 }
15 fc = n FieldCls()
si (fc.fld_x == 10) { z.o("PASS:access_s4") }
// S5: static method on class
clase StatCls { público estático 11 add(11 num_a, 11 num_b) { r num_a + num_b } }
si (StatCls.add(3, 4) == 7) { z.o("PASS:access_s5") }
// S6: static method on instance
15 sc = n StatCls()
si (sc.add(5, 6) == 11) { z.o("PASS:access_s6") }
// S7: multiple static methods
clase MathOps { público estático 11 add(11 num_a, 11 num_b) { r num_a + num_b } público estático 11 mul(11 num_a, 11 num_b) { r num_a * num_b } }
si (MathOps.add(2, 3) == 5 && MathOps.mul(2, 3) == 6) { z.o("PASS:access_s7") }
