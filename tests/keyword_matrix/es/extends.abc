#alphabet<es>
// === EXTENDS TESTS ===
clase Animal { público 12 aname = "" público método 12 speak() { r "..." } }
// S1: inherit method + field
clase Dog extiende Animal { público método 12 speak() { r "woof" } }
15 d = n Dog()
d.aname = "Rex"
si (d.speak() == "woof" && d.aname == "Rex") { z.o("PASS:ext_s1") }
// S2: inherit field
15 a = n Animal()
a.aname = "Generic"
si (a.aname == "Generic") { z.o("PASS:ext_s2") }
// S3: override method
clase Cat extiende Animal { público método 12 speak() { r "meow" } }
15 ct = n Cat()
si (ct.speak() == "meow") { z.o("PASS:ext_s3") }
// S4: child adds method
clase Robot extiende Animal { público método 11 beep() { r 42 } }
15 rb = n Robot()
si (rb.beep() == 42 && rb.speak() == "...") { z.o("PASS:ext_s4") }
// S5: child adds field
clase Pet extiende Animal { público 5 loyalty = 100 }
15 pt = n Pet()
si (pt.loyalty == 100) { z.o("PASS:ext_s5") }
// S6: 3-level chain
clase Base { público método 11 base_fn() { r 1 } }
clase Mid extiende Base { público método 11 mid_fn() { r 2 } }
clase Top extiende Mid { público método 11 top_fn() { r 3 } }
15 tp = n Top()
si (tp.base_fn() == 1 && tp.mid_fn() == 2 && tp.top_fn() == 3) { z.o("PASS:ext_s6") }
