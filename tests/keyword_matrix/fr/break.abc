#alphabet<fr>
// === BREAK TESTS ===
// S1: exits loop
5 val_a = 0
boucle (true) { val_a = val_a + 1 si (val_a == 5) { rompre } }
si (val_a == 5) { z.o("PASS:break_s1") }
// S2: inside if in loop
5 val_b = 0
boucle (true) { val_b = val_b + 1 si (val_b == 3) { si (true) { rompre } } }
si (val_b == 3) { z.o("PASS:break_s2") }
// S3: inside nested loop
5 inner = 0
5 outer = 0
boucle (outer < 5) { inner = 0 boucle (true) { inner = inner + 1 si (inner == 2) { rompre } } outer = outer + 1 }
si (inner == 2 && outer == 5) { z.o("PASS:break_s3") }
// S4: at end of body
5 val_c = 0
boucle (val_c < 10) { val_c = val_c + 1 rompre }
si (val_c == 1) { z.o("PASS:break_s4") }
// S5: conditional break
13 nums = [1, 2, 3, 4, 5]
5 idx_a = 0
5 found_val = 0
boucle (idx_a < z.len(nums)) { si (nums[idx_a] == 3) { found_val = nums[idx_a] rompre } idx_a = idx_a + 1 }
si (found_val == 3) { z.o("PASS:break_s5") }
// S6: break after some iterations
5 cnt_a = 0
5 acc = 0
boucle (cnt_a < 10) { acc = acc + cnt_a cnt_a = cnt_a + 1 si (cnt_a == 4) { rompre } }
si (cnt_a == 4 && acc == 6) { z.o("PASS:break_s6") }
// S7: multiple break points
5 mode = 1
5 out = 0
boucle (true) { si (mode == 1) { out = 10 rompre } si (mode == 2) { out = 20 rompre } out = 30 rompre }
si (out == 10) { z.o("PASS:break_s7") }
// S8: break with counter check
5 idx_b = 0
5 sum_a = 0
boucle (idx_b < 5) { sum_a = sum_a + idx_b idx_b = idx_b + 1 si (idx_b == 3) { rompre } }
si (sum_a == 3) { z.o("PASS:break_s8") }
