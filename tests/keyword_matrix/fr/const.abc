#alphabet<fr>
// === CONST TESTS ===
// S1: const int
constante 5 MAX = 100
si (MAX == 100) { z.o("PASS:const_s1") }
// S2: const string
constante 12 CNAME = "Alphabet"
si (CNAME == "Alphabet") { z.o("PASS:const_s2") }
// S3: const bool
constante 11 DEBUG = true
si (DEBUG) { z.o("PASS:const_s3") }
// S4: const float
constante 8 CPI = 3.14
si (z.type(CPI) == "number") { z.o("PASS:const_s4") }
// S5: const in expression
constante 5 CLIMIT = 10
5 half = CLIMIT / 2
si (half == 5) { z.o("PASS:const_s5") }
// S6: const passed to function
méthode 11 check_limit(11 num_a) { r num_a < 100 }
si (check_limit(MAX)) { z.o("PASS:const_s6") }
// S7: const in function scope
méthode 11 use_const() { constante 5 LOCAL = 50 r LOCAL }
si (use_const() == 50) { z.o("PASS:const_s7") }
