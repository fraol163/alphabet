#alphabet<en>
x "../../stdlib/crypto.abc"
5 ok = 1
t {
  5 h1 = hash_simple("hello")
  i (h1 == null || h1 == 0) { ok = 0 }
  5 h2 = hash_djb2("hello")
  i (h2 == null || h2 == 0) { ok = 0 }
  5 h3 = hash_fnv1a("hello")
  i (h3 == null || h3 == 0) { ok = 0 }
  5 cs = checksum("abc")
  i (cs < 0 || cs > 255) { ok = 0 }
  5 hex = hash_to_hex(255)
  i (hex != "ff") { ok = 0 }
} h (0 e) { ok = 0 }
i (ok) {
  z.o("PASS: crypto")
} e {
  z.o("FAIL: crypto")
}
