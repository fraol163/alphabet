#alphabet<en>
x "../../stdlib/system.abc"
5 ok = 1
t {
  5 home = env_get("HOME")
  i (home == null) { ok = 0 }
  i (env_has("HOME") != 1) { ok = 0 }
  i (env_has("NONEXISTENT_VAR_12345") != 0) { ok = 0 }
} h (0 e) { ok = 0 }
t {
  5 pa = platform_name()
  i (pa == null) { ok = 0 }
  5 ar = platform_arch()
  i (ar == null) { ok = 0 }
} h (0 e) { ok = 0 }
t {
  5 all = env_all()
  i (all == null) { ok = 0 }
} h (0 e) { ok = 0 }
i (ok) {
  z.o("PASS: system")
} e {
  z.o("FAIL: system")
}
