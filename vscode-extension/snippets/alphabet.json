{
  "If Statement": {
    "prefix": "if",
    "body": ["i (${1:condition}) {", "  $0", "}"],
    "description": "If statement"
  },
  "If-Else": {
    "prefix": "ifelse",
    "body": ["i (${1:condition}) {", "  $2", "} e {", "  $0", "}"],
    "description": "If-else statement"
  },
  "Loop": {
    "prefix": "loop",
    "body": ["l (${1:i} = 0 : ${1:i} < ${2:10} : ${1:i} = ${1:i} + 1) {", "  $0", "}"],
    "description": "For loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": ["l (${1:condition}) {", "  $0", "}"],
    "description": "While loop"
  },
  "Class": {
    "prefix": "class",
    "body": ["c ${1:Name} {", "  $0", "}"],
    "description": "Class declaration"
  },
  "Method": {
    "prefix": "method",
    "body": ["v m ${1:5} ${2:name}(${3:params}) {", "  $0", "}"],
    "description": "Public method"
  },
  "Function": {
    "prefix": "func",
    "body": ["m ${1:5} ${2:name}(${3:params}) {", "  $0", "}"],
    "description": "Top-level function"
  },
  "Try-Catch": {
    "prefix": "try",
    "body": ["t {", "  $1", "} h (${2:err}) {", "  $0", "}"],
    "description": "Try-catch block"
  },
  "Print": {
    "prefix": "print",
    "body": ["z.o(${1:value})"],
    "description": "Print output"
  },
  "Lambda": {
    "prefix": "lambda",
    "body": ["m(${1:param}) { $0 }"],
    "description": "Lambda expression"
  },
  "Destructuring": {
    "prefix": "destr",
    "body": ["[${1:a}, ${2:b}] = ${3:[1, 2]}"],
    "description": "Destructuring assignment"
  },
  "Header": {
    "prefix": "header",
    "body": ["#alphabet<${1:en}>"],
    "description": "Language header"
  }
}