{
  "name": "alphabet",
  "scopeName": "source.abc",
  "fileTypes": ["abc"],
  "patterns": [
    {"include": "#comments"},
    {"include": "#keywords"},
    {"include": "#strings"},
    {"include": "#numbers"},
    {"include": "#types"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {"name": "comment.line.double-slash.abc", "match": "//.*$"}
      ]
    },
    "keywords": {
      "patterns": [
        {"name": "keyword.control.abc", "match": "\\b(if|else|loop|break|continue|return|try|handle|match)\\b"},
        {"name": "keyword.other.abc", "match": "\\b(class|abstract|interface|method|new|public|private|static|import|export|const)\\b"},
        {"name": "keyword.other.abc", "match": "\\b(i|e|l|b|k|r|c|a|j|m|n|v|p|s|t|h|z|x|q)\\b"}
      ]
    },
    "strings": {
      "patterns": [
        {"name": "string.quoted.double.abc", "begin": "\"", "end": "\"", "patterns": [{"name": "constant.character.escape.abc", "match": "\\\\(n|t|r|\\\\|\"|0)"}]},
        {"name": "string.raw.abc", "match": "r\"[^\"]*\""}
      ]
    },
    "numbers": {
      "patterns": [
        {"name": "constant.numeric.abc", "match": "\\b[0-9]+(\\.[0-9]+)?\\b"}
      ]
    },
    "types": {
      "patterns": [
        {"name": "support.type.abc", "match": "\\b(void|int|str|bool|list|map|float|i8|i16|i32|i64|f32|f64|dec|cpx)\\b"}
      ]
    }
  }
}